rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Client cannot self-grant premium or inflate server counters.
    function safeUserFields() {
      return !request.resource.data.keys().hasAny([
        'isPremium',
        'premiumPlan',
        'premiumActivatedAt',
        'videoCvCount',
      ]) || (
        resource != null
        && request.resource.data.get('isPremium', resource.data.get('isPremium', false))
            == resource.data.get('isPremium', false)
        && request.resource.data.get('videoCvCount', resource.data.get('videoCvCount', 0))
            == resource.data.get('videoCvCount', 0)
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && safeUserFields();
      allow update: if isOwner(userId) && safeUserFields();
      allow delete: if isOwner(userId);

      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /coachChat/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }

      match /assessments/{assessmentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /videoCvJobs/{jobId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
  }
}
