# Local development (copy to .env and load before npm start)
PORT=8080
FUNCTION_REGION=us-central1

# AI — FYP demo: use Gemini (recommended)
GEMINI_API_KEY=
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: OpenAI for cartoon avatars / legacy coach
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# VirtuoMate Intelligence Engine (Cloud Run) — required for cloud coaching assessor
INTELLIGENCE_ENGINE_URL=https://virtuomate-intelligence-do3iebspxq-uc.a.run.app
# WHISPER_MODEL=whisper-1

# Payments — mock activates premium instantly; set stripe when integrating Stripe
PAYMENT_MODE=mock

# Limits (must match lib/services/app_service.dart freeSessionLimit = 20)
FREE_SESSION_LIMIT=20

# Image cartoon avatars (optional)
OPENAI_IMAGE_MODEL=gpt-image-1

# Admin users (comma-separated emails)
ADMIN_EMAILS=admin@virtuomate.app

# CORS — set your app origin in production
CORS_ORIGIN=*
